# Preferred database configuration. The app derives ASYNC_DATABASE_URL and
# ROOT_DATABASE_URL automatically for MySQL when these are omitted.
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/busgpt
# ASYNC_DATABASE_URL=mysql+aiomysql://root:123456@127.0.0.1:3306/busgpt
# ROOT_DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/

# Backward-compatible fallback when DATABASE_URL is not set.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=123456
# DB_NAME=busgpt

SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_ENABLED=true
ORDER_EXPIRE_MINUTES=30
